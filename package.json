{
  "name": "bean-execution-gateway-poc",
  "version": "0.1.0",
  "description": "Public beta POC for routing outcomes to owned agents, public paths, build decisions, or blocked execution before compute runs.",
  "private": true,
  "type": "module",
  "homepage": "https://bean-execution-gateway-poc.onrender.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/beanscg/bean-execution-gateway-poc.git"
  },
  "keywords": [
    "ai-agents",
    "agent-routing",
    "agent-marketplace",
    "execution-gateway",
    "build-vs-buy",
    "agent-orchestration",
    "openapi",
    "public-beta"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "start": "npm run gateway:server:hosted-demo",
    "gateway:demo": "npm run gateway:server:hosted-demo",
    "gateway:server:hosted-demo": "BEAN_GATEWAY_HOSTED_DEMO=1 node scripts/execution-gateway-server.mjs --host 0.0.0.0 --port ${PORT:-8787}",
    "gateway:smoke:hosted": "node scripts/execution-gateway.mjs hosted-smoke --base-url ${BEAN_GATEWAY_BASE_URL:-http://127.0.0.1:8787}",
    "gateway:verify": "node scripts/execution-gateway.mjs verify --out dist/execution-gateway/verification",
    "launch:readiness": "node scripts/product-launch-readiness.mjs --out dist/execution-gateway/product-launch-readiness.json",
    "retrospective:experiments": "node scripts/retrospective-experiments.mjs --out dist/execution-gateway/retrospective-experiments"
  }
}
