{
  "name": "Bean Execution Gateway",
  "slug": "bean-execution-gateway",
  "version": "0.1.0",
  "api_version": "v0",
  "description": "Public beta POC that routes outcomes to owned agents, public paths, build decisions, or blocked execution before compute runs.",
  "homepage": "https://bean-execution-gateway-poc.onrender.com",
  "repository": "https://github.com/beanscg/bean-execution-gateway-poc",
  "public_beta_status": "prepared_for_trusted_external_review",
  "first_user_readiness_status": "complete_for_trusted_beta_review",
  "input_scope": ["public", "synthetic"],
  "blocked_input_scope": ["private", "secret", "regulated", "customer_data", "company_data", "local_file", "internal"],
  "endpoints": [
    { "method": "GET", "path": "/v0/health", "purpose": "Health and safety-mode check" },
    { "method": "GET", "path": "/v0/ready", "purpose": "Readiness and production gate status" },
    { "method": "GET", "path": "/v0/metrics", "purpose": "Metadata-only runtime metrics" },
    { "method": "GET", "path": "/v0/examples", "purpose": "Return proof examples and hero metric definitions" },
    { "method": "POST", "path": "/v0/path", "purpose": "Return the best current owned-agent, public-path, or build-decision route for an outcome" },
    { "method": "POST", "path": "/v0/route", "purpose": "Return route decision for a public or synthetic outcome request" },
    { "method": "POST", "path": "/v0/feedback", "purpose": "Record metadata-only route usefulness feedback" },
    { "method": "POST", "path": "/v0/dispatch", "purpose": "Disabled dispatch endpoint that proves V0 never executes externally" },
    { "method": "POST", "path": "/v0/outcomes", "purpose": "Record outcome locally or in hosted-demo memory" },
    { "method": "GET", "path": "/v0/ledger/summary", "purpose": "Summarize outcome records" },
    { "method": "GET", "path": "/v0/openapi.json", "purpose": "OpenAPI contract" },
    { "method": "GET", "path": "/v0/v1/goals", "purpose": "Return the 80-goal V1 local-contract checklist" },
    { "method": "GET", "path": "/v0/v1/readiness", "purpose": "Report V1 public-demo and production blockers" },
    { "method": "POST", "path": "/v0/v1/tenants", "purpose": "Create a scoped tenant contract without storing API keys" },
    { "method": "POST", "path": "/v0/v1/context/envelopes", "purpose": "Create a metadata-only context envelope and block private context" },
    { "method": "POST", "path": "/v0/v1/supplier-bids", "purpose": "Score supplier bid quality, speed, cost, and risk without external execution" },
    { "method": "POST", "path": "/v0/v1/acceptance", "purpose": "Record outcome acceptance without payable settlement" },
    { "method": "POST", "path": "/v0/v1/payment-quotes", "purpose": "Quote payment intent while blocking chargeable payment rails" },
    { "method": "POST", "path": "/v0/v1/abuse/cases", "purpose": "Queue metadata-only abuse cases" },
    { "method": "GET", "path": "/v0/v1/audit", "purpose": "Summarize metadata-only V1 audit events" },
    { "method": "GET", "path": "/v0/v1/replay", "purpose": "Summarize metadata-only replay and learning metrics" },
    { "method": "GET", "path": "/v0/v2/goals", "purpose": "Return the 120-goal full-product public contract map" },
    { "method": "GET", "path": "/v0/v2/readiness", "purpose": "Report public-learning readiness and private/customer/paid blockers" },
    { "method": "POST", "path": "/v0/v2/intake", "purpose": "Submit an outcome and receive a metadata-only route decision" },
    { "method": "POST", "path": "/v0/v2/route", "purpose": "Alias for V2 outcome intake and route decision" },
    { "method": "POST", "path": "/v0/v2/supply/bids", "purpose": "Record supplier capability metadata without external execution" },
    { "method": "POST", "path": "/v0/v2/execution/plans", "purpose": "Create dry-run or human-approval execution plans" },
    { "method": "POST", "path": "/v0/v2/acceptance", "purpose": "Record acceptance and block payable settlement" },
    { "method": "POST", "path": "/v0/v2/feedback", "purpose": "Record metadata-only product learning feedback" },
    { "method": "POST", "path": "/v0/v2/trust/review", "purpose": "Review public/private safety gates" },
    { "method": "GET", "path": "/v0/v2/learning", "purpose": "Summarize V2 metadata-only learning records" },
    { "method": "GET", "path": "/v0/v2/ops", "purpose": "Summarize operations readiness" },
    { "method": "GET", "path": "/v0/v2/quality", "purpose": "Summarize quality-system readiness" },
    { "method": "GET", "path": "/v0/v2/commercial", "purpose": "Summarize legal and commercial readiness" },
    { "method": "GET", "path": "/v0/v2/gtm", "purpose": "Return go-to-market packet" },
    { "method": "GET", "path": "/v0/open-demand/examples", "purpose": "Return open-demand proof examples" },
    { "method": "GET", "path": "/v0/open-demand/learning", "purpose": "Summarize public-only learning counters" },
    { "method": "POST", "path": "/v0/open-demand/path", "purpose": "Alias for the agent path decision endpoint" },
    { "method": "POST", "path": "/v0/open-demand/scan", "purpose": "Scan fixture or read-only public GitHub demand" },
    { "method": "POST", "path": "/v0/open-demand/opportunities/{opportunity_id}/bundle", "purpose": "Build a local task packet" },
    { "method": "POST", "path": "/v0/open-demand/tasks/{task_id}/run", "purpose": "Run static verifier and evidence packet loop" },
    { "method": "POST", "path": "/v0/open-demand/feedback", "purpose": "Record metadata-only open-demand feedback" }
  ],
  "hero_metrics_v0": [
    "executable_path_rate",
    "time_to_ranked_paths_seconds",
    "unsafe_actions_prevented"
  ],
  "path_scores_v0": [
    "quality",
    "speed",
    "cost",
    "risk",
    "proofability",
    "learning_value",
    "trainability",
    "execution_readiness"
  ],
  "guarantees_v0": {
    "spend_usd": 0,
    "external_writes": 0,
    "external_executions": 0,
    "hosted_demo_request_body_persistence": false,
    "hosted_demo_request_body_logging": false,
    "external_supplier_execution": false,
    "dispatch_enabled": false,
    "security_headers_enabled": true,
    "rate_limiting_enabled": true,
    "v1_local_contract_goals": 80,
    "v1_completed_local_contract_goals": 80,
    "v1_customer_or_paid_traffic_ready": false,
    "v1_external_supplier_selectable": false,
    "v1_nonzero_payment_chargeable": false,
    "v2_full_product_contract_goals": 120,
    "v2_completed_public_contract_goals": 120,
    "v2_private_customer_or_paid_traffic_ready": false,
    "v2_raw_prompt_storage": false,
    "v2_external_supplier_execution": false,
    "v2_payment_transfer": false,
    "customer_traffic_ready": false,
    "public_beta_invites_sent": false,
    "public_posts_sent": false
  },
  "public_beta_docs": [
    "docs/public-beta-readiness.md",
    "docs/public-beta-positioning.md",
    "docs/public-beta-onboarding.md",
    "docs/public-beta-feedback-and-support.md",
    "docs/public-beta-operations.md",
    "docs/public-beta-decision-packet.md",
    "docs/public-beta-learning-metrics.md"
  ],
  "first_user_docs": [
    "docs/evaluator-quickstart.md",
    "docs/how-to-review.md",
    "docs/example-results.md",
    "docs/first-user-readiness.md"
  ],
  "policy_blocks": [
    "requires_private_repo_access",
    "requires_paid_api",
    "requires_public_post",
    "requires_account_credentials",
    "requires_external_supplier",
    "requires_regulated_data",
    "unsafe_or_disallowed"
  ],
  "current_executor_classes": ["current_agent", "local_runner", "local_tool"],
  "future_executor_classes": ["workflow", "external_supplier"],
  "future_executor_classes_status": "represented_as_blocked_classes_in_v0",
  "verification_commands": [
    "npm run gateway:verify",
    "npm run gateway:smoke:hosted",
    "BEAN_GATEWAY_BASE_URL=https://bean-execution-gateway-poc.onrender.com npm run gateway:smoke:hosted"
  ]
}
